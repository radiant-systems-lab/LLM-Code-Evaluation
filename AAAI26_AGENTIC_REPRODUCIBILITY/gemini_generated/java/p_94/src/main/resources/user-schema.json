{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "User",
  "description": "Schema for a user object",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Name of the user",
      "minLength": 2,
      "maxLength": 50
    },
    "email": {
      "type": "string",
      "description": "Email of the user",
      "format": "email"
    },
    "age": {
      "type": "integer",
      "description": "Age of the user",
      "minimum": 0,
      "maximum": 120
    }
  },
  "required": ["name", "email", "age"]
}
